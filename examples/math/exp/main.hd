import std::io
import std::math
fn main(): void {
    let s: float = math::sqrt(4.0);
    let e: float = math::exp(1.0);
    let e2: float = math::exp2(3.0);
    let l: float = math::log(1.0);
    let l10: float = math::log10(100.0);
    let l2: float = math::log2(8.0);
    io::printf("%f\n", s);
    io::printf("%f\n", e);
    io::printf("%f\n", e2);
    io::printf("%f\n", l);
    io::printf("%f\n", l10);
    io::printf("%f\n", l2);
}
