import std::io
import std::math
fn main(): void {
    let fl: float = math::floor(2.9);
    let ce: float = math::ceil(2.1);
    let tr: float = math::trunc(2.9);
    let ro: float = math::round(2.5);
    io::printf("%f\n", fl);
    io::printf("%f\n", ce);
    io::printf("%f\n", tr);
    io::printf("%f\n", ro);
}
